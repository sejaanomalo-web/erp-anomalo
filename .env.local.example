# Copie para `.env.local` e preencha após criar o projeto Supabase dedicado.

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Resend (e-mail transacional) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL=erp@anomalohub.com

# ----- Sentry (monitoramento de erros) -----
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- PWA -----
# Defina como "true" em produção para registrar o service worker.
ENABLE_PWA=false
